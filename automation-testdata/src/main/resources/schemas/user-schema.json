{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User",
  "type": "object",
  "required": ["id", "name", "email"],
  "properties": {
    "id":     { "type": "integer" },
    "name":   { "type": "string" },
    "email":  { "type": "string", "format": "email" },
    "role":   { "type": "string", "enum": ["admin", "user", "qa"] },
    "active": { "type": "boolean" }
  }
}
