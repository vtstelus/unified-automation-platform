<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Unified Automation Platform — Full Suite"
       parallel="tests"
       thread-count="4"
       data-provider-thread-count="3"
       verbose="1">

    <listeners>
        <listener class-name="com.platform.core.listener.TestEventListener"/>
    </listeners>

    <test name="UI Tests">
        <groups><run>
            <include name="ui"/>
            <include name="smoke"/>
        </run></groups>
        <packages>
            <package name="com.platform.tests.ui"/>
        </packages>
    </test>

    <test name="API Tests">
        <groups><run>
            <include name="api"/>
        </run></groups>
        <packages>
            <package name="com.platform.tests.api"/>
        </packages>
    </test>

    <test name="Mobile Tests">
        <groups><run>
            <include name="mobile"/>
        </run></groups>
        <packages>
            <package name="com.platform.tests.mobile"/>
        </packages>
    </test>

    <test name="Regression">
        <groups><run>
            <include name="regression"/>
            <include name="e2e"/>
        </run></groups>
        <packages>
            <package name="com.platform.tests.regression"/>
        </packages>
    </test>

</suite>
