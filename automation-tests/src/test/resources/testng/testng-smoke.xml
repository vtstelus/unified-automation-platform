<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Smoke Suite" parallel="tests" thread-count="2" verbose="1">

    <listeners>
        <listener class-name="com.platform.core.listener.TestEventListener"/>
    </listeners>

    <test name="Smoke">
        <groups><run>
            <include name="smoke"/>
        </run></groups>
        <packages>
            <package name="com.platform.tests"/>
        </packages>
    </test>

</suite>
