<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Regression Suite" parallel="methods" thread-count="6" verbose="1">

    <listeners>
        <listener class-name="com.platform.core.listener.TestEventListener"/>
    </listeners>

    <test name="Full Regression">
        <groups><run>
            <include name="regression"/>
        </run></groups>
        <packages>
            <package name="com.platform.tests"/>
        </packages>
    </test>

</suite>
